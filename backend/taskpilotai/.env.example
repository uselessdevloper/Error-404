# LLM Provider Configuration
# Choose one: gemini, nvidia, or grok
LLM_PROVIDER=gemini

# API Keys - Provide key for your chosen provider
GEMINI_API_KEY=your_gemini_api_key_here
NVIDIA_API_KEY=your_nvidia_api_key_here
GROK_API_KEY=your_grok_api_key_here

# LLM Model Settings
LLM_MODEL=gemini-2.5-flash
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2048

# Database Configuration (Optional - works in demo mode without Supabase)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_KEY=your_service_role_key
SUPABASE_PROJECT_ID=your_project_id
SUPABASE_PROJECT_REGION=us-central1

# Server Configuration
TASKPILOT_PORT=8787
TASKPILOT_DATASET_DIR=./datasets
TASKPILOT_TEE_MODE=local-attested

# Task Prioritization Weights
PRIORITY_WEIGHT_SEVERITY=0.4
PRIORITY_WEIGHT_DEADLINE=0.3
PRIORITY_WEIGHT_DEPENDENCIES=0.2
PRIORITY_WEIGHT_BUSINESS_IMPACT=0.1

# Deduplication Settings
DEDUP_SIMILARITY_THRESHOLD=0.85

# Vertex AI & Google Cloud Platform Integration (Funded by GCP Billing Credits)
GCP_PROJECT_ID=your_gcp_project_id
GCP_BILLING_ACCOUNT_ID=524914727
VERTEX_AI_PROJECT=your_gcp_project_id
VERTEX_AI_LOCATION=us-central1
